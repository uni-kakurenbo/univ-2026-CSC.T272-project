{
    "name": "@app/server",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "exports": {
        "./server-app": "./src/app.ts",
        "./app-type": "./src/appType.ts"
    },
    "scripts": {
        "build": "bun build --target bun --outfile dist/main.js src/main.ts",
        "collect:intelligence-matrix": "bun run src/tools/collectIntelligenceMatrix.ts",
        "dev": "bun run src/main.ts",
        "start": "bun run src/main.ts --port 3000",
        "view:cli": "bun run src/tools/cliViewer.ts",
        "test": "bun test src",
        "typecheck": "tsc --noEmit -p tsconfig.json"
    },
    "dependencies": {
        "@app/shared": "workspace:*",
        "hono": "4.12.27"
    },
    "devDependencies": {
        "@types/bun": "1.3.14",
        "typescript": "6.0.3"
    }
}
