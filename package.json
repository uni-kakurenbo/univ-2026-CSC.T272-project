{
    "name": "univ-2026-csc-t272-project",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "workspaces": [
        "apps/*"
    ],
    "scripts": {
        "adapter:duck": "bun run --filter @app/adaptor duck",
        "adapter:sphinx": "bun run --filter @app/adaptor sphinx",
        "build": "bun run --filter @app/visualizer build",
        "build:agents": "bun run --filter @app/adaptor build:agents",
        "build:server": "bun run --filter @app/server build && bun run --filter @app/runner build && bun run --filter @app/adaptor build",
        "check": "bun run scripts/runChecks.ts check",
        "check:fix": "bun run scripts/runChecks.ts fix",
        "check:format": "prettier --check --cache .",
        "check:format:fix": "prettier --write --cache .",
        "check:lint": "eslint . --cache",
        "check:lint:fix": "eslint . --fix --cache",
        "check:type": "bun run scripts/runChecks.ts type",
        "collect:intelligence-matrix": "bun run --filter @app/server collect:intelligence-matrix",
        "dev:server": "bun run --filter @app/server dev",
        "dev:visualizer": "bun run --filter @app/visualizer dev",
        "prepare": "husky",
        "start:server": "bun run --filter @app/server start",
        "test": "bun run --filter @app/runner test && bun run --filter @app/server test",
        "view:cli": "bun run --filter @app/server view:cli"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/bun": "^1.3.14",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsonc": "^3.2.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-unicorn": "^65.0.1",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "prettier": "^3.8.4",
        "typescript-eslint": "^8.61.0"
    }
}
